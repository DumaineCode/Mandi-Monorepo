STORE_CORS=http://localhost:8000,https://docs.medusajs.com
ADMIN_CORS=http://localhost:5173,http://localhost:9000,https://docs.medusajs.com
AUTH_CORS=http://localhost:5173,http://localhost:9000,https://docs.medusajs.com
REDIS_URL=redis://localhost:6379
JWT_SECRET=supersecret
COOKIE_SECRET=supersecret
DATABASE_URL=
DB_NAME=medusa-backend

# --- Provider settings (change: admin-provider-settings) ---
# Provider credentials now live ENCRYPTED IN THE DATABASE, managed from the
# Admin panel (Provider Settings). Only the two vars below remain env-based.

# ACTIVE — Key-Encryption Key for provider secrets (AES-256-GCM). REQUIRED.
# Must be base64 OR hex decoding to exactly 32 bytes. Generate one with:
#   openssl rand -base64 32
# Losing this key means all stored provider secrets become undecryptable and
# every provider resolves as unconfigured — re-paste credentials via the admin
# panel after setting a new key. Keep it stable and backed up per environment.
PROVIDER_SETTINGS_ENCRYPTION_KEY=

# ACTIVE — Publicly reachable backend URL used to build MP notification_url
# (webhooks). Stays env-based (not stored in the DB).
BACKEND_PUBLIC_URL=

# --- DEPRECATED provider env vars (removal window) ---
# The vars below are read ONCE by the one-time seed:
#   npx medusa exec ./src/scripts/seed-provider-settings.ts
# to import existing credentials into the encrypted DB store. After the seed has
# run, the DB is strictly authoritative — these vars are NOT consulted at
# runtime (changing them has no effect). Populate them ONLY for the initial
# migration seed, then remove them once every environment is seeded. Manage all
# provider credentials from the Admin > Provider Settings panel going forward.

# DEPRECATED (seed-only) — Openpay (cards + 3DS)
#   required set for seed: MERCHANT_ID, PRIVATE_KEY, WEBHOOK_USER, WEBHOOK_PASSWORD
OPENPAY_MERCHANT_ID=
OPENPAY_PRIVATE_KEY=
OPENPAY_PUBLIC_KEY=
# "true" (default) seeds sandbox mode; "false" seeds production mode.
OPENPAY_SANDBOX=true
OPENPAY_WEBHOOK_USER=
OPENPAY_WEBHOOK_PASSWORD=

# DEPRECATED (seed-only) — Mercado Pago (Checkout Pro)
#   required set for seed: ACCESS_TOKEN, WEBHOOK_SECRET, BACKEND_PUBLIC_URL
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
MP_WEBHOOK_SECRET=

# DEPRECATED (seed-only) — Skydropx (fulfillment quotes + labels)
#   required set for seed: API_KEY, ORIGIN_ZIP
SKYDROPX_API_KEY=
# Optional override; defaults to https://api.skydropx.com/v1
SKYDROPX_BASE_URL=
SKYDROPX_ORIGIN_ZIP=
# Optional; "false" opts out of tax-inclusive pricing (default is inclusive).
SKYDROPX_TAX_INCLUSIVE=
