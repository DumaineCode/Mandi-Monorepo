# --- MX payments & shipping (change: mx-payments-shipping) ---
# A provider is enabled ONLY when its FULL required set is present;
# partial configuration logs a warning and skips that provider at boot.

# Openpay (cards + 3DS) — required set: MERCHANT_ID, PRIVATE_KEY, WEBHOOK_USER, WEBHOOK_PASSWORD
OPENPAY_MERCHANT_ID=
OPENPAY_PRIVATE_KEY=
# Public key is consumed by the storefront (NEXT_PUBLIC_OPENPAY_PUBLIC_KEY); documented here for parity.
OPENPAY_PUBLIC_KEY=
# "true" (default) uses sandbox-api.openpay.mx; set "false" for production.
OPENPAY_SANDBOX=true
# Basic-auth credentials registered with the webhook in the Openpay dashboard.
OPENPAY_WEBHOOK_USER=
OPENPAY_WEBHOOK_PASSWORD=

# Mercado Pago (Checkout Pro) — required set: ACCESS_TOKEN, WEBHOOK_SECRET, BACKEND_PUBLIC_URL
MP_ACCESS_TOKEN=
# Public key is consumed by the storefront (NEXT_PUBLIC_MP_PUBLIC_KEY); documented here for parity.
MP_PUBLIC_KEY=
MP_WEBHOOK_SECRET=
# Publicly reachable backend URL used to build MP notification_url (webhooks).
BACKEND_PUBLIC_URL=

# Skydropx (fulfillment quotes + labels) — required set: API_KEY, ORIGIN_ZIP
SKYDROPX_API_KEY=
# Optional override; defaults to https://api.skydropx.com/v1
SKYDROPX_BASE_URL=
# Origin postal code used for quotations when the stock location lacks one.
SKYDROPX_ORIGIN_ZIP=
