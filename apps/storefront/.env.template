# Storefront environment template (change: mx-payments-shipping).
# Copy to .env.local and fill in the values.

# --- Starter base ---
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=
NEXT_PUBLIC_BASE_URL=http://localhost:8000
# MX-first storefront: default region is Mexico (SF-5). The starter degrades
# gracefully (region picker / clear error) while the MX region doesn't exist.
NEXT_PUBLIC_DEFAULT_REGION=mx

# --- Openpay (cards + 3DS, slice S3) ---
# Cross-reference: backend .env.template OPENPAY_* vars.
NEXT_PUBLIC_OPENPAY_MERCHANT_ID=
NEXT_PUBLIC_OPENPAY_PUBLIC_KEY=
NEXT_PUBLIC_OPENPAY_SANDBOX=true

# --- Mercado Pago (Checkout Pro, slice S4) ---
NEXT_PUBLIC_MP_PUBLIC_KEY=
