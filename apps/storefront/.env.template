# Storefront environment template (change: mx-payments-shipping).
# Copy to .env.local and fill in the values.

# --- Starter base ---
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=
NEXT_PUBLIC_BASE_URL=http://localhost:8000
# MX-first storefront: default region is Mexico (SF-5). The starter degrades
# gracefully (region picker / clear error) while the MX region doesn't exist.
NEXT_PUBLIC_DEFAULT_REGION=mx

# --- DEPRECATED provider config (change: admin-provider-settings) ---
# Openpay public config (merchant id, public key, sandbox flag) is now fetched
# at RUNTIME from the backend endpoint GET /store/provider-config, which serves
# the values managed in Admin > Provider Settings. The NEXT_PUBLIC_OPENPAY_*
# and NEXT_PUBLIC_MP_PUBLIC_KEY vars are no longer read by the storefront and
# can be removed once every environment is on the runtime endpoint. Key
# rotation no longer requires a storefront rebuild.

# DEPRECATED — no longer read (served via /store/provider-config)
NEXT_PUBLIC_OPENPAY_MERCHANT_ID=
NEXT_PUBLIC_OPENPAY_PUBLIC_KEY=
NEXT_PUBLIC_OPENPAY_SANDBOX=true

# DEPRECATED — no longer read (served via /store/provider-config)
NEXT_PUBLIC_MP_PUBLIC_KEY=
